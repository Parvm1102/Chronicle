# ─── PostgreSQL (local Docker or Supabase) ───
# Local:
DATABASE_URL=postgresql://novel_reader:changeme@localhost:5432/novel_reader
# Supabase (uncomment and fill in):
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# POSTGRES_SSL=require

# ─── LLM ───
# Providers: ollama, cloud (Groq/OpenRouter), gemini
LLM_PROVIDER=ollama
# Ollama (local):
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3.5:4b
# For bigger context window with smaller model, use qwen3.5:2b
# Cloud (Groq / OpenRouter — uncomment and fill in):
# LLM_PROVIDER=cloud
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile
# LLM_API_KEY=your-api-key-here

# Gemini (Cloud):
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# LLM_MODEL=gemini-1.5-flash
LLM_MAX_CONTEXT=8192
LLM_TEMPERATURE=0.3
LLM_MAX_RETRIES=3

# ─── Voice Samples ───
VOICE_SAMPLES_DIR=./voice_samples

# ─── Novel Parsing ───
ENABLE_NOVEL_PARSING=false
PARSE_MAX_RETRIES=3
PARSE_CONTEXT_WINDOW=3
PARSE_DIALOGUE_HISTORY_SIZE=8

# ─── Vector DB / RAG (Qdrant) ───
# Pass 3 indexes the full novel into Qdrant after Pass 2. Off by default.
ENABLE_RAG_INDEXING=false
# Local Docker (docker compose up -d qdrant) — no API key needed:
QDRANT_URL=http://localhost:6333
# From inside the docker-compose network the app would use: http://qdrant:6333
# Managed Qdrant Cloud (uncomment and fill in; leave the local URL above commented):
# QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.region.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key
# Optional: use the faster gRPC transport (needs the gRPC port 6334 exposed).
# QDRANT_PREFER_GRPC=false
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
RAG_COLLECTION=novel_rag
# Models (all ONNX via FastEmbed — no torch required):
RAG_EMBED_MODEL=BAAI/bge-base-en-v1.5
RAG_EMBED_DIM=768
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_RERANK_MODEL=BAAI/bge-reranker-base
# GPU acceleration for dense embedding + reranking (optional).
# Requires: torch, sentence-transformers, llama-index-embeddings-huggingface.
# Sparse (BM25) vectors always stay on CPU. Leave false for the CPU-only path.
RAG_USE_GPU=false
RAG_DEVICE=cuda
# Chunking (tokens):
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
# Retrieval funnel: hybrid candidates -> rerank -> final top_k.
RAG_RETRIEVE_K=40
RAG_RERANK_K=20
RAG_TOP_K=8
# Temporal proximity boost: score *= 1 + alpha * exp(-chapter_distance / decay).
RAG_TEMPORAL_ALPHA=0.15
RAG_TEMPORAL_DECAY=5.0

# ─── TTS (Chatterbox-Turbo narration service) ───
# Base URL of the standalone TTS microservice (tts_service/).
# Local Docker / local uvicorn: http://localhost:8070
# From inside docker-compose network the main app would use: http://tts:8070
# Modal (later): set to the deployed web endpoint URL.
TTS_SERVICE_URL=http://localhost:8070
# Where generated wavs are cached (kept in sync with the service via mounts).
TTS_CACHE_DIR=./data/tts_cache
# Fallback voice actor for narration when no narrator character/actor is assigned.
TTS_DEFAULT_NARRATOR_ACTOR=Sohee
# Sliding-window depth: how many upcoming lines to keep synthesized ahead of the
# line currently being spoken (spills into the next chapter near a boundary).
TTS_LOOKAHEAD=4
# Host port the TTS container publishes (compose reads TTS_PORT).
TTS_PORT=8070
# Device for the TTS service: cuda (GPU), mps (Apple Silicon), or cpu.
TTS_DEVICE=cuda
